# ══════════════════════════════════════════
#  LA CIMA BARBERÍA — Variables de Entorno
# ══════════════════════════════════════════

# ─── Entorno ──────────────────────────────
NODE_ENV=development

# ─── Base de Datos PostgreSQL ─────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lacima_db
DB_USER=lacima_user
DB_PASSWORD=lacima_secret_2024

# ─── JWT (Authentication) ─────────────────
JWT_SECRET=CAMBIA_ESTE_SECRET_EN_PRODUCCION_min32chars
JWT_EXPIRES_IN=7d

# ─── WhatsApp Business API (Meta) ─────────
# Obtener en: https://developers.facebook.com
WHATSAPP_TOKEN=tu_token_de_whatsapp_business_api
WHATSAPP_PHONE_ID=tu_phone_number_id
WHATSAPP_VERIFY_TOKEN=token_para_verificacion_webhook

# ─── Matias API (Facturación DIAN) ────────
# Obtener en: https://matias-api.com
MATIAS_API_KEY=tu_api_key_de_matias
MATIAS_API_URL=https://api.matias-api.com/v1

# ─── URLs ─────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
